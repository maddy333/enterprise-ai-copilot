PROJECT_NAME="Enterprise AI Copilot"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="your-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=copilot_db
POSTGRES_PORT=5432
# Construct connection strings in config:
# SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Vector DB (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM 
# Options: openai, vllm, local
LLM_PROVIDER=openai
OPENAI_API_KEY="sk-something"
# VLLM_API_URL=http://localhost:8080/v1
# VLLM_API_KEY=dummy

# Embeddings
EMBEDDING_MODEL_NAME="BAAI/bge-large-en-v1.5"
