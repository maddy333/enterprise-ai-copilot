# Enterprise AI Copilot - Production Environment Variables

# ==========================================
# Core Application Settings
# ==========================================
PROJECT_NAME="Enterprise AI Copilot"
LLM_PROVIDER=openai
API_V1_STR="/api/v1"
SECRET_KEY="production-super-secret-key-change-me-later"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# Database Configuration
# (Used by docker-compose and the Python backend)
# ==========================================
POSTGRES_SERVER=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_strong_password_123
POSTGRES_DB=copilot_db
POSTGRES_PORT=5432

# ==========================================
# External Service Connections
# (Refers to docker container names)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ==========================================
# AI / LLM Integration
# ==========================================
# LLM Configuration
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyA3nnIDgWOyBHAgQIvhjz0sf3XN1J8Sk_w

# Embedding Model (used locally via sentence-transformers)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# ==========================================
# Hugging Face Configuration (For gated models)
# ==========================================
# Add your Hugging Face API Token here to allow vLLM to download the model
HUGGING_FACE_HUB_TOKEN=hf_your_actual_token_here
